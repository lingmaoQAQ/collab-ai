# CollabAI 配置示例
# 复制为 .env 并填入 API Key

# ---- 模型服务 ----
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (GPT)
OPENAI_API_KEY=sk-xxx

# DeepSeek (OpenAI Chat 兼容)
DEEPSEEK_API_KEY=sk-xxx

# 自定义 OpenAI Chat 兼容服务 (Ollama / vLLM 等)
# OPENAI_CHAT_API_KEY=xxx
# OPENAI_CHAT_BASE_URL=http://localhost:11434/v1

# ---- 默认模型 ----
COLLABAI_MODEL=deepseek-chat
COLLABAI_PROVIDER=deepseek

# ---- 通知（可选，不配则不启用）----
# Slack: 创建 Incoming Webhook 后填入
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# 钉钉: 创建机器人后填入 Webhook 地址
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 通用 Webhook（自定义通知目标）
# NOTIFY_WEBHOOK_URL=https://your-server.com/notify
