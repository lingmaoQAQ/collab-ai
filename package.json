  "description": "AI 多用户协作框架 — AI 作为团队技术协作者",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "collab-ai": "cli.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
