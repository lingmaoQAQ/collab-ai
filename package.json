{
  "name": "collab-ai",
  "version": "1.4.0",
  "description": "AI 多用户协作框架 — AI 作为团队技术协作者",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "collab-ai": "cli.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx cli.mjs",
    "start": "node cli.mjs",
    "chat": "node cli.mjs chat",
    "gateway": "node cli.mjs gateway",
    "test": "node --import tsx test/regression.ts && node --import tsx test/tier2-test.ts && node --import tsx test/new-features.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^5.2.1",
    "openai": "^6.45.0",
    "partial-json": "^0.1.7",
    "typebox": "^1.3.6",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
